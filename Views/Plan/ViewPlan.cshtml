@using TropicalBudget.Utilities
@model Plan
@{
    ViewData["Title"] = "Plan";

    int nextMonth = Model.startDate.AddMonths(1).Month;
    int nextYear = Model.startDate.AddMonths(1).Year;
    int previousMonth = Model.startDate.AddMonths(-1).Month;
    int previousYear = Model.startDate.AddMonths(-1).Year;
    Dictionary<string, string> newTransactionRouteData = new()
    {
        {"budgetID", Model.Budget.ID.ToString()}
    };
    Dictionary<string, string> fullTransactionRouteData = new()
    {
        {"budgetID", Model.Budget.ID.ToString()},
        {"year", Model.startDate.Year.ToString()},
        {"month", Model.startDate.Month.ToString()},
    };

    List<IGrouping<Guid, Transaction>> categoryGroupedExpenses = Model.Transactions.Where(transaction => transaction.TransactionType == TransactionUtility.TRANSACTION_TYPE_EXPENSE).GroupBy(transaction => transaction.CategoryID).ToList();

    decimal plannedExpenses = Model.PlanItems.Where(item => item.TransactionType == TransactionUtility.TRANSACTION_TYPE_EXPENSE).Sum(item => item.Amount);
}
<div class="text-center">
    <h2 class="fs-1">Plan: @Model.Budget.Name</h2>
    <div class="d-flex justify-content-between align-items-center gap-2 p-1 my-2 rounded-pill">
        <div onclick="previousMonth()" style="cursor:pointer" class="btn-outline-primary border border-primary d-flex align-items-center py-1 px-4 rounded-pill">
            <i class="bi bi-chevron-left fs-4" style="cursor:pointer"></i>
            <span class="d-none d-sm-block">@(Model.startDate.AddMonths(-1).ToString("MMMM, yyyy"))</span>
        </div>
        <div class="d-flex flex-column gap-2">
            <p class="fs-5 fw-bold m-0">@Model.currentMonth</p>
            <p class="fs-6 fw-normal m-0 text-uppercase">@(Model.Transactions.Count) transactions</p>
        </div>
        <div onclick="nextMonth()" style="cursor:pointer" class="bg-primary d-flex align-items-center text-white py-1 px-4 rounded-pill">
            <span class="d-none d-sm-block">@(Model.startDate.AddMonths(1).ToString("MMMM, yyyy"))</span>
            <i class="bi bi-chevron-right fs-4"></i>
        </div>
    </div>
    <partial name="~/Views/Home/_SpendingListBanner.cshtml" model="Model.Transactions" />
    <div class="d-flex gap-3 bg-light p-2 justify-content-center align-items-center rounded-pill">
        <p>Planned Expenses: @($"{plannedExpenses:c}")</p>
    </div>
</div>

@* Button row *@
<div class="d-flex flex-wrap justify-content-end align-items-center gap-2 my-3">
    <a class="text-decoration-none py-1 px-4 d-block rounded-pill d-flex gap-2 btn btn-primary border" asp-controller="Plan" asp-action="New" asp-all-route-data="fullTransactionRouteData">
        <span>Add New Category</span>
        <i class="bi bi-plus-circle"></i>
    </a>
    <a class="text-decoration-none py-1 px-4 d-block rounded-pill d-flex gap-2 btn btn-outline-primary border border-primary" asp-controller="Plan" asp-action="Index" asp-all-route-data="newTransactionRouteData">
        <span>Today</span>
        <i class="bi bi-calendar-check"></i>
    </a>
    <a id="spendingListButton" class="text-decoration-none py-1 px-4 rounded-pill d-flex gap-2 btn-outline-secondary border border-secondary" asp-controller="Transaction" asp-action="Index" asp-all-route-data="fullTransactionRouteData" style="cursor:pointer">
        <span>Transactions</span>
        <i class="bi bi-card-list"></i>
    </a>
    <a id="spendingListButton" class="text-decoration-none py-1 px-4 rounded-pill d-flex gap-2 btn-outline-success border border-success" asp-controller="Insights" asp-action="Index" asp-all-route-data="fullTransactionRouteData" style="cursor:pointer">
        <span>Insights</span>
        <i class="bi bi-graph-up-arrow"></i>
    </a>
</div>

<div class="d-flex flex-column gap-2">
    @if(Model.PlanItems != null && Model.PlanItems.Count > 0){
        foreach(PlanItem planItem in Model.PlanItems){
            <div role="button" class="d-flex flex-column gap-1 bg-light rounded px-4 py-2" onclick="editTransaction('@(planItem.ID)')">
                <div class="d-flex gap-2 justify-content-between align-items-center">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="rounded-circle" style="width:20px; height:20px; background-color: @planItem.CategoryColor; display:block"></span>
                        <div>
                            <span>@(planItem.CategoryName)</span>
@*                             @if(planItem.TransactionType == TransactionUtility.TRANSACTION_TYPE_EXPENSE){
                                <span>@(Math.Round((planItem.Amount/plannedExpenses) * 100))%</span>
                            } *@
                        </div>
                    </div>
                    <div>
                        <span class="fw-normal fs-6">
                            @{
                                decimal transactionSum = 0;
                                if (Model.Transactions.Any(x => x.CategoryID == planItem.CategoryID)){
                                    transactionSum = Model.Transactions.Where(x => x.CategoryID == planItem.CategoryID).Sum(x => x.Amount);
                                    // transactionSum = transactionsForCategory.Sum();

                                }
                                decimal transactionPercentage = (transactionSum / planItem.Amount) * 100;
                            }
                            @($"{transactionSum:c}") / @($"{planItem.Amount:c}")
                        </span>
                       
                    </div>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @(transactionPercentage)%; background-color: @(planItem.CategoryColor);" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
        }
    }
</div>

<script>
const nextMonth = () =>{
    location.href = "@Url.Action("Index", "Plan")" + `?budgetID=${"@(Model.Budget.ID.ToString())"}&year=${@(nextYear)}&month=${@(nextMonth)}`;
}
const previousMonth = () =>{
    location.href = "@Url.Action("Index", "Plan")" + `?budgetID=${"@(Model.Budget.ID.ToString())"}&year=${@(previousYear)}&month=${@(previousMonth)}`;
}
const editTransaction = (plan_id) => {
    location.href = "@Url.Action("Edit", "Plan")" +  `?budgetID=${"@(Model.Budget.ID.ToString())"}&year=${@(Model.startDate.Year)}&month=${@(Model.startDate.Month)}&planID=${plan_id}`;
}
</script>